{
  "name": "lap",
  "version": "0.1.0",
  "private": true,
  "description": "LAP - Life Action Plan",
  "author": "LAP Team <lap@lacrypta.ar>",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "doctor:local": "node scripts/local-doctor.mjs",
    "doctor:deploy": "node scripts/deploy-doctor.mjs",
    "smoke:local": "npm run db:push && npm run doctor:local",
    "smoke:deploy": "npm run build && npm run doctor:deploy",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.41",
    "@getalby/sdk": "^3.2.0",
    "ai": "^6.0.116",
    "drizzle-orm": "^0.32.1",
    "framer-motion": "^12.38.0",
    "luxon": "^3.4.4",
    "next": "^15.0.0",
    "postgres": "^3.4.5",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/luxon": "^3.4.2",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.23.0",
    "eslint": "^9.15.0",
    "eslint-config-next": "^15.0.0",
    "jsdom": "^29.0.0",
    "typescript": "^5.9.3",
    "vitest": "^2.0.4"
  }
}
