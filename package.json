{
  "name": "lap",
  "version": "0.1.0",
  "description": "LAP — Life Action Plan",
  "main": "./out/main/index.js",
  "author": "LAP Team <lap@lacrypta.ar>",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "rebuild": "cd node_modules/better-sqlite3 && npx prebuild-install --runtime electron --target 33.4.0 --arch x64 || npx @electron/rebuild -f -w better-sqlite3",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "test": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@getalby/sdk": "^3.2.0",
    "better-sqlite3": "^11.1.2",
    "drizzle-orm": "^0.32.1",
    "luxon": "^3.4.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron/rebuild": "^3.6.1",
    "@types/better-sqlite3": "^7.6.11",
    "@types/luxon": "^3.4.2",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "drizzle-kit": "^0.23.0",
    "electron": "^33.4.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^2.0.4"
  }
}
